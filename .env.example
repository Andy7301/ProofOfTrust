# → apps/web/.env.local (optional repo root .env merged in next.config.ts)

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_TRON_NETWORK=nile
# 1 = browser mock store, not /api
NEXT_PUBLIC_USE_MOCK_CLIENT=

# Toggles: mock / empty = use real paths when keys are set
AI_PROVIDER=
SOLANA_X402_DISABLE=
TRON_REPAYMENT_MODE=
FILECOIN_AUDIT_MODE=

# Solana x402 — agent pays; fund SOL + USDC on devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_AGENT_PRIVATE_KEY=
SOLANA_X402_NETWORK=solana-devnet
SOLANA_USDC_MINT=
SOLANA_X402_PAYMENT_MICRO_USDC=1000
# USDC recipient (not the agent key)
NEXT_PUBLIC_X402_DEMO_PAY_TO=
X402_DEMO_BYPASS=

# TRON — user repays to treasury
TRON_RPC_URL=https://nile.trongrid.io
TRON_REPAY_RECEIVER=
TRON_SUN_PER_DEBT_DOLLAR=100000

GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_STRICT_QUOTA=

# Filecoin OOC (Synapse) — PieceCID audit blobs; needs tFIL + USDFC on Calibration
FILECOIN_CALIBRATION_RPC_URL=https://rpc.ankr.com/filecoin_testnet
SYNAPSE_PRIVATE_KEY=
