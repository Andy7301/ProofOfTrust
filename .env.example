# App
NEXT_PUBLIC_APP_NAME=ProofOfTrust
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Explorers (client): Solana tx links + TRON repay links
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# nile | shasta | mainnet — must match where you repay / TRON_RPC_URL
NEXT_PUBLIC_TRON_NETWORK=nile

# Client: set to 1 to use in-browser mock store instead of JSON-backed API (see apps/web/src/lib/store.ts)
NEXT_PUBLIC_USE_MOCK_CLIENT=

# Runtime toggles — leave unset for “real” when the matching secret/RPC exists; set to mock to force off
# AI: real when GEMINI_API_KEY is set and AI_PROVIDER is not mock
AI_PROVIDER=
# Set to 1 to skip on-chain x402 (keeps key in .env but no USDC spend)
SOLANA_X402_DISABLE=
# TRON repay verification: default real; set mock to skip chain check
TRON_REPAYMENT_MODE=
ARKHAI_MODE=
FILECOIN_AUDIT_MODE=

# --- Solana x402 (server “agent” wallet) ---
# SOLANA_AGENT_PRIVATE_KEY is the PAYER: this keypair signs SPL transfers and pays SOL fees.
# Nothing auto-tops it up — you send devnet SOL + devnet USDC to this wallet’s addresses first.
# SOLANA_USDC_MINT is WHICH token the x402 “invoice” uses (Faremeter exact scheme), not “who gets paid”.
# The recipient of that USDC is NEXT_PUBLIC_X402_DEMO_PAY_TO (merchant), not the agent.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_AGENT_PRIVATE_KEY=
# e.g. solana-devnet — must match RPC cluster (see @faremeter/info)
SOLANA_X402_NETWORK=solana-devnet
# SPL mint for the asset named in x402 accepts[] (default = devnet USDC)
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Must match /api/x402/demo accepts[].amount (0.001 USDC = 1000)
SOLANA_X402_PAYMENT_MICRO_USDC=1000

# x402 demo route — base58 that RECEIVES the USDC from the agent (set this; avoid placeholder)
NEXT_PUBLIC_X402_DEMO_PAY_TO=
# Set to 1 to allow ?bypass=1 or env-only skip (development / judging convenience)
X402_DEMO_BYPASS=

# TRON (Nile)
TRON_NETWORK=nile
TRON_RPC_URL=https://nile.trongrid.io
TRON_PRIVATE_KEY=
# Base58 treasury that receives TRX repayments (required for wallet repay + verification)
TRON_REPAY_RECEIVER=
# Sun per $1 of debt (default 100000 = 0.1 TRX per dollar)
TRON_SUN_PER_DEBT_DOLLAR=100000

# Gemini
GEMINI_API_KEY=

# --- Option B: Alkahest on Base Sepolia (EVM escrow / attestations) ---
# Get Base Sepolia ETH: https://www.alchemy.com/faucets/base-sepolia
ALKAHEST_RPC_URL=https://sepolia.base.org
# viem: 0x + 64 hex chars
ALKAHEST_PRIVATE_KEY=

# --- Option B: Synapse / Filecoin Onchain Cloud on Calibration ---
# Fund wallet: tFIL (gas) + test USDFC (storage) — see Filecoin Onchain Cloud docs
FILECOIN_CALIBRATION_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
SYNAPSE_PRIVATE_KEY=
# Optional: only if a specific provider docs require an API key
FILECOIN_API_KEY=
